<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 填充色改为纯黑色 -->
    <solid android:color="#FF000000" />
    <!-- 圆角，让边框更柔和，可根据喜好调整 -->
    <corners android:radius="20dp" />
    <!-- 内边距，让灯和边框有间隔 -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp" />
</shape>